<header class="sticky top-0 z-50 border-b border-cyan-900/50 bg-slate-900/80 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">

    <!-- LOGO 区域 -->
    <div class="flex items-center gap-3 group cursor-pointer">
      <!-- 一个纯 CSS 画的呼吸灯 -->
      <div class="w-3 h-3 bg-fuchsia-500 rounded-full shadow-[0_0_10px_rgba(217,70,239,0.8)] animate-pulse"></div>

      <!-- 渐变文字 LOGO -->
      <span class="text-xl font-bold tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-fuchsia-500 group-hover:from-fuchsia-400 group-hover:to-cyan-500 transition-all duration-500">
        ZERO_TASK
      </span>
    </div>

    <!-- 用户状态栏 -->
    <nav class="flex items-center gap-4">
      <% if user_signed_in? %>
        <span class="text-xs text-slate-500 hidden sm:block"><%= current_user.email %></span>
        <!-- 登出按钮：像是一个红色的紧急开关 -->
        <%= button_to "Sign Out",
              destroy_user_session_path,
              method: :delete,
              class: "cursor-pointer text-xs font-bold text-red-500 " \
                     "hover:text-red-400 hover:bg-red-950/30 px-3 py-1 " \
                     "border border-transparent hover:border-red-900 " \
                     "rounded transition-all duration-300 tracking-wider" %>
      <% else %>
        <%= link_to "INITIATE", new_user_session_path, class: "text-sm text-cyan-400 hover:text-cyan-300" %>
      <% end %>
    </nav>
  </div>
</header>
