<%= turbo_stream.prepend "tasks_list", partial: "tasks/task", locals: { task: @task } %>

<%= turbo_stream.replace "new_task_form" do %>
  <%= form_with(model: [current_user, Task.new], id: "new_task_form", class: "flex items-center") do |f| %>
    <%= f.text_field :description,
        placeholder: "Enter new task description...",
        class: "flex-1 bg-transparent text-cyan-400 placeholder-cyan-800 border-none focus:ring-0 text-xl px-4 py-3 font-mono outline-none",
        autocomplete: "off",
        autofocus: true %>
    <%= f.submit "ADD",
        class: "cursor-pointer bg-cyan-500/20 text-cyan-400 hover:bg-cyan-500 hover:text-black border border-cyan-500 px-8 py-3 font-bold tracking-widest transition-colors duration-300" %>
  <% end %>
<% end %>
