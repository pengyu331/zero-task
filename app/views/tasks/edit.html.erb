<%= turbo_frame_tag @task do %>
  <%= form_with(
        model: [current_user, @task],
        class: "flex items-center w-full p-2 border border-blue-500 bg-blue-950/30 " \
               "shadow-[0_0_10px_rgba(59,130,246,0.2)]"
      ) do |f| %>

    <%= f.text_field :description,
          class: "flex-1 bg-transparent text-blue-400 border-none focus:ring-0 " \
                 "font-mono outline-none placeholder-blue-800",
          autofocus: true %>

    <div class="flex gap-2 ml-4">
      <%= f.submit "SAVE",
            class: "cursor-pointer text-xs px-3 py-1 bg-cyan-900/30 text-cyan-400 " \
                   "border border-cyan-500 hover:bg-cyan-500 hover:text-black transition-colors" %>

      <%= link_to "CANCEL",
            user_tasks_path(current_user),
            class: "text-xs px-3 py-1 bg-zinc-800 text-zinc-400 border border-zinc-600 " \
                   "hover:text-white transition-colors flex items-center" %>
    </div>
  <% end %>
<% end %>
