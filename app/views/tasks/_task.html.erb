<%= turbo_frame_tag task do %>
  <div class="group flex items-center justify-between p-4 border border-cyan-900 bg-zinc-900/50 hover:bg-zinc-900 hover:border-cyan-500 transition-all duration-300">
    <div class="flex items-center gap-4 flex-1">
      <%# 稍后加入 Checkbox %>

      <div class="flex flex-col">
        <span class="text-lg <%= task.completed? ? "text-zinc-600 line-through" : "text-cyan-300" %>">
          <%= task.description %>
        </span>
        <span class="text-xs text-cyan-700/70">[CREATED: <%= task.created_at.strftime("%b %-d, %Y, %I:%M %p").upcase %>]</span>
      </div>
    </div>

    <div class="flex gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
      <%= link_to "EDIT",
            edit_user_task_path(current_user, task),
            class: "text-xs px-3 py-1 bg-blue-900/30 text-blue-400 border " \
                   "border-blue-500 hover:bg-blue-500 hover:text-black transition-colors" %>

      <button type="button"
              data-controller="modal"
              data-action="modal#open"
              data-modal-url-value="<%= user_task_path(current_user, task) %>"
              class="text-xs px-3 py-1 bg-red-900/30 text-red-400 border border-red-500 hover:bg-red-500 hover:text-black ↪ transition-colors">
        REMOVE
      </button>
    </div>
  </div>
<% end %>
