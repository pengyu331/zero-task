<%= turbo_frame_tag task do %>
  <div class="group flex items-center justify-between p-4 border border-cyan-900 bg-zinc-900/50 hover:bg-zinc-900 hover:border-cyan-500 transition-all duration-300">
    <div class="flex items-center gap-4 flex-1">
      <%= form_with(model: [current_user, task], data: {controller: "autosubmit"}, class: "flex items-center m-0") do |f| %>
        <label class="group relative flex items-center cursor-pointer">
          <%= f.check_box :state,
                {checked: task.completed?, data: {action: "change->autosubmit#submit"}, class: "sr-only"},
                "completed",
                "active" %>

          <div class="w-6 h-6 rounded border-2 border-cyan-500 bg-black
                group-has-checked:bg-cyan-500 group-has-checked:border-cyan-400
                group-has-checked:shadow-[0_0_12px_rgba(34,197,94,0.7)]
                transition-all duration-200 flex items-center justify-center">

            <svg class="w-4 h-4 text-black opacity-0 scale-50
                        group-has-checked:opacity-100 group-has-checked:scale-100
                        transition-all duration-200 ease-out"
                  fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
        </label>
      <% end %>

      <div class="flex flex-col">
        <span class="text-lg <%= task.completed? ? "text-zinc-600 line-through" : "text-cyan-300" %>">
          <%= task.description %>
        </span>
        <span class="text-xs text-cyan-700/70">[CREATED: <%= task.created_at.strftime("%b %-d, %Y, %I:%M %p").upcase %>]</span>
      </div>
    </div>

    <div class="flex gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
      <%= link_to "EDIT",
            edit_user_task_path(current_user, task),
            class: "text-xs px-3 py-1 bg-blue-900/30 text-blue-400 border " \
                   "border-blue-500 hover:bg-blue-500 hover:text-black transition-colors" %>

      <button type="button"
              data-controller="modal"
              data-action="modal#open"
              data-modal-url-value="<%= user_task_path(current_user, task) %>"
              class="text-xs px-3 py-1 bg-red-900/30 text-red-400 border border-red-500 hover:bg-red-500 hover:text-black ↪ transition-colors">
        REMOVE
      </button>
    </div>
  </div>
<% end %>
