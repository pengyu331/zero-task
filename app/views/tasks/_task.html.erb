<div id="<%= dom_id(task) %>" class="group flex items-center justify-between p-4 rounded-xl border border-cyan-900 bg-zinc-900/50 hover:bg-zinc-900 hover:border-cyan-500 transition-all duration-300">
  <div class="flex items-center gap-4 flex-1">
    <%# 稍后加入 Checkbox %>
    <div class="flex flex-col">
      <span class="text-lg <%= task.completed? ? "text-zinc-600 line-through" : "text-cyan-300" %>">
        <%= task.description %>
      </span>
      <span class="text-xs text-cyan-700/70">[CREATED: <%= task.created_at.strftime("%b %-d, %Y, %I:%M %p").upcase %>]
      </span>
    </div>
  </div>
  <div class="flex gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
    <%# 预留 Edit 和 Remove 按钮的位置 %>
  </div>
</div>
