<div class="min-h-screen bg-zinc-950 text-cyan-400 font-mono p-8 selection:bg-cyan-900 selection:text-cyan-100">
  <div class="max-w-4xl mx-auto">

    <header class="mb-10 border-b border-cyan-500/30 pb-4 flex justify-between items-end">
      <div>
        <h1 class="text-4xl font-black uppercase tracking-widest drop-shadow-[0_0_10px_rgba(34,197,94,0.8)]">
          Task List
        </h1>
        <p class="text-xs text-cyan-600 mt-2">// USER_ID: <%= current_user.id %> // STATUS: ONLINE</p>
      </div>
    </header>

    <div class="mb-10 bg-black border-l-4 border-cyan-500 p-1">
      <%= render "form", task: @new_task %>
    </div>

    <div class="mb-6 bg-zinc-900 border border-cyan-900 p-4 flex flex-col md:flex-row justify-between items-center gap-4">
      <%= form_with(
            url: user_tasks_path(current_user),
            method: :get,
            data: {turbo_frame: "tasks_list"},
            class: "flex flex-col md:flex-row w-full gap-4 items-center"
          ) do |f| %>
        <%# Filter 按钮组 %>
        <div class="flex gap-2">
          <% %w[all active completed].each do |status| %>
            <label class="cursor-pointer">
              <%= f.radio_button(
                    :status,
                    status,
                    checked: params[:status] == status || (params[:status].blank? && status == "all"),
                    class: "peer sr-only",
                    data: {controller: "autosubmit", action: "change->autosubmit#submit"}
                  ) %>
              <div class="px-4 py-2 border border-zinc-700 text-zinc-500 peer-checked:border-cyan-500 peer-checked:text-cyan-400 hover:text-cyan-300 uppercase text-xs tracking-widest transition-colors font-bold">
                <%= status.upcase %>
              </div>
            </label>
          <% end %>
        </div>
        <%# Search Bar %>
        <div class="flex-1 w-full md:w-auto flex justify-end">
          <div class="relative w-full md:w-64">
            <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-cyan-700">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            </div>
            <%= f.text_field :query,
                  value: params[:query],
                  placeholder: "SCAN KEYWORDS...",
                  class: "w-full pl-10 pr-4 py-2 bg-black border border-cyan-900 " \
                         "focus:border-cyan-500 text-cyan-400 focus:ring-0 text-sm font-mono outline-none" %>
          </div>
          <%= f.submit "SEARCH", class: "hidden" %>
        </div>
      <% end %>
    </div>

    <div class="mt-8 border border-cyan-500/20 bg-black/50 p-6 rounded shadow-[0_0_15px_rgba(34,197,94,0.1)]">
      <div id="tasks_list" class="flex flex-col gap-4">
        <%= render @tasks %>
      </div>

      <div class="mt-8 flex justify-center text-sm">
        <%= paginate @tasks %>
      </div>
    </div>

  </div>
</div>

<dialog id="delete_modal" data-controller="dialog" class="m-auto bg-zinc-950 border border-red-500 p-8 shadow-[0_0_30px_rgba(239,68,68,0.3)] text-red-400 font-mono backdrop:bg-black/80 backdrop:backdrop-blur-sm rounded-none">
  <div class="flex flex-col items-center">
    <div class="text-5xl mb-4 animate-pulse">⚠️</div>
    <h3 class="text-xl font-bold mb-2 uppercase tracking-widest text-red-500">Destructive Action Detected</h3>
    <p class="text-zinc-400 text-sm mb-8 text-center max-w-sm">Are you certain you wish to purge this task? This procedure cannot be reversed.</p>

    <div class="flex gap-4 w-full">
      <form method="dialog" class="flex-1">
        <button class="w-full py-2 cursor-pointer border border-zinc-600 text-zinc-400 hover:bg-zinc-800 hover:text-white transition-colors">CANCEL</button>
      </form>

      <%= button_to "PURGE",
            "",
            method: :delete,
            id: "confirm_delete_btn",
            form: {data: {action: "turbo:submit-end->dialog#closeOnSuccess"}},
            class: "flex-1 py-2 px-8 cursor-pointer border border-red-500 bg-red-900/30 " \
                   "hover:bg-red-500 hover:text-black font-bold transition-colors" %>
    </div>
  </div>
</dialog>
