<div class="min-h-screen bg-zinc-950 text-cyan-400 font-mono p-8 selection:bg-cyan-900 selection:text-cyan-100">
  <div class="max-w-4xl mx-auto">

    <header class="mb-10 border-b border-cyan-500/30 pb-4 flex justify-between items-end">
      <div>
        <h1 class="text-4xl font-black uppercase tracking-widest drop-shadow-[0_0_10px_rgba(34,197,94,0.8)]">
          Task List
        </h1>
        <p class="text-xs text-cyan-600 mt-2">// USER_ID: <%= current_user.id %> // STATUS: ONLINE</p>
      </div>
    </header>

    <div class="mb-10 bg-black border-l-4 border-cyan-500 p-1">
      <%= render "form", task: @new_task %>
    </div>

    <div class="mt-8 border border-cyan-500/20 bg-black/50 p-6 rounded shadow-[0_0_15px_rgba(34,197,94,0.1)]">
      <div id="tasks_list" class="flex flex-col gap-4">
        <%= render @tasks %>
      </div>

      <div class="mt-8 flex justify-center text-sm">
        <%= paginate @tasks %>
      </div>
    </div>

  </div>
</div>
