<div class="min-h-screen bg-gray-950 text-gray-200 p-8 font-mono">
  <!-- Header -->
  <header class="mb-12 border-b border-gray-800 pb-4 flex justify-between items-end">
    <div>
      <h1 class="text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-600 tracking-tighter uppercase">
        Dashboard
      </h1>
      <p class="text-xs text-cyan-600 mt-2">// USER_ID: <%= current_user.id %> // STATUS: ONLINE</p>
    </div>
  </header>
  <!-- Middle Stats -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">

    <div class="relative bg-gray-900 border border-cyan-500 p-6 shadow-[0_0_15px_rgba(6,182,212,0.3)] hover:shadow-[0_0_25px_rgba(6,182,212,0.6)] transition-shadow duration-300">
      <div class="absolute top-0 left-0 w-2 h-full bg-cyan-500"></div>
      <div class="flex items-center space-x-3 mb-4">
        <svg class="w-6 h-6 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <h3 class="text-cyan-400 text-sm font-bold uppercase tracking-widest">Completion Rate</h3>
      </div>
      <div class="text-5xl font-black text-cyan-50" id="stat_completion">
        36%
      </div>
    </div>

    <div class="relative bg-gray-900 border border-blue-500 p-6 shadow-[0_0_15px_rgba(59,130,246,0.3)] hover:shadow-[0_0_25px_rgba(59,130,246,0.6)] transition-shadow duration-300">
      <div class="absolute top-0 left-0 w-2 h-full bg-blue-500"></div>
      <div class="flex items-center space-x-3 mb-4">
        <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path></svg>
        <h3 class="text-blue-400 text-sm font-bold uppercase tracking-widest">Total Tasks</h3>
      </div>
      <div class="text-5xl font-black text-blue-50" id="stat_total">
        42
      </div>
    </div>

    <div class="relative bg-gray-900 border border-fuchsia-500 p-6 shadow-[0_0_15px_rgba(217,70,239,0.3)] hover:shadow-[0_0_25px_rgba(217,70,239,0.6)] transition-shadow duration-300">
      <div class="absolute top-0 left-0 w-2 h-full bg-fuchsia-500"></div>
      <div class="flex items-center space-x-3 mb-4">
        <svg class="w-6 h-6 text-fuchsia-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
        <h3 class="text-fuchsia-400 text-sm font-bold uppercase tracking-widest">Current Month</h3>
      </div>
      <div class="text-5xl font-black text-fuchsia-50" id="stat_month">
        7
      </div>
    </div>

    <div class="relative bg-gray-900 border border-orange-500 p-6 shadow-[0_0_15px_rgba(249,115,22,0.3)] hover:shadow-[0_0_25px_rgba(249,115,22,0.6)] transition-shadow duration-300">
      <div class="absolute top-0 left-0 w-2 h-full bg-orange-500"></div>
      <div class="flex items-center space-x-3 mb-4">
        <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <h3 class="text-orange-400 text-sm font-bold uppercase tracking-widest">Last 3 Months</h3>
      </div>
      <div class="text-5xl font-black text-orange-50" id="stat_quarter">
        15
      </div>
    </div>
  </div>
  <!-- Bottom: Recent Activity -->
  <div class="bg-gray-900 border border-gray-800 p-8 shadow-2xl relative overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:20px_20px] pointer-events-none"></div>

    <div class="relative z-10">
      <div class="flex items-baseline space-x-4 mb-8 border-b border-gray-800 pb-4">
        <svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        <h2 class="text-3xl font-black text-gray-100 uppercase tracking-tight">Recent Activity</h2>
        <span class="text-xs text-gray-500 uppercase tracking-widest font-bold">Latest system operations</span>
      </div>

      <ul class="space-y-4" id="recent_activities">
        <li class="flex items-center text-sm text-gray-400 border-l-2 border-gray-700 pl-4 py-1 hover:border-emerald-400 transition-colors">
           <span class="text-gray-600 mr-4 font-mono">[2026-03-16 18:29:46]</span>
           <span class="text-emerald-400 mr-2">SYS_INIT</span>
           Dashboard layout successfully loaded into Zero_Task.
        </li>
      </ul>
    </div>
  </div>
</div>
